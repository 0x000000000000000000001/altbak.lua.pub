#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p run/bak/js/output run/bak/js/spago
rm -rf output .spago spago.yaml spago.lock
ln -s run/bak/js/output output
ln -s run/bak/js/spago .spago
ln -s run/bak/js/spago.yaml spago.yaml
touch run/bak/js/spago.lock && ln -s run/bak/js/spago.lock spago.lock
npx spago build > /dev/null 2>&1

echo "=== Native Node V8 ==="
time node -e "import('./output/App/index.js').then(m => m.main())"
