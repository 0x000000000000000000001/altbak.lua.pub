#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p run/bak/es/output-purs run/bak/js/spago
rm -rf output .spago spago.yaml spago.lock
ln -s run/bak/es/output-purs output
ln -s run/bak/js/spago .spago
ln -s run/bak/js/spago.yaml spago.yaml
touch run/bak/es/spago.lock && ln -s run/bak/es/spago.lock spago.lock

ENTRY_POINT="App"

if [ "$1" == "--x" ]; then
  ENTRY_POINT="AppX"
  # Temporarily inject extended tests
  cp -r srx/Test/* src/Test/
  cp srx/AppX.purs src/
  trap "rm -rf src/Test/STArray.purs src/Test/AffOperations.purs src/Test/StringOps.purs src/Test/FileOps src/AppX.purs" EXIT
fi

export PATH="$PWD/run/bak/js/node_modules/.bin:$PATH"
spago build > /dev/null 2>&1
purs-backend-es build --output-dir run/bak/es/output > /dev/null 2>&1
find run/bak/es/output-purs -name "foreign.js" | while read -r f; do
  dest="run/bak/es/output/$(basename $(dirname $f))"
  mkdir -p "$dest"
  cp "$f" "$dest/foreign.js"
done


echo "=== Arista ES ==="
time node -e "import('./run/bak/es/output/' + '$ENTRY_POINT' + '/index.js').then(m => m.main())"
