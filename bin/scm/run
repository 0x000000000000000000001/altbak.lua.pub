#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p run/bak/scm/output run/bak/scm/spago
rm -rf output .spago spago.yaml spago.lock
ln -s run/bak/scm/output output
ln -s run/bak/scm/spago .spago
ln -s run/bak/scm/spago.yaml spago.yaml
touch run/bak/scm/spago.lock && ln -s run/bak/scm/spago.lock spago.lock
export PATH="$PWD/run/bak/js/node_modules/.bin:$PATH"
spago build > /dev/null 2>&1
PATH="$(pwd)/bin/scm:$PATH" purescm build > /dev/null 2>&1
PATH="$(pwd)/bin/scm:$PATH" purescm bundle-app --main App > /dev/null 2>&1

echo "=== Chez Scheme ==="
export DYLD_LIBRARY_PATH="/opt/homebrew/lib:/opt/homebrew/opt/icu4c/lib"
time chez --program run/bak/scm/output/main
